{
  "name": "sql-chat",
  "version": "1.0.0",
  "description": "Natural Language to SQL for Oracle, MySQL, and PostgreSQL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build --prefix frontend",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.chatwithdb.sqlchat",
    "productName": "SQL Chat",
    "directories": {
      "output": "dist/electron"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "dist/backend/app.exe",
        "to": "bin/app.exe"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "templates/**/*"
    ]
  },
  "keywords": [
    "sql",
    "chat",
    "ai",
    "database"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
